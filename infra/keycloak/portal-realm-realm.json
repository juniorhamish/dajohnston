{
  "id": "portal-realm",
  "realm": "portal-realm",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "verifyEmail": true,
  "clients": [
    {
      "clientId": "portal-frontend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "webOrigins": [
        "http://localhost:3000"
      ],
      "redirectUris": [
        "http://localhost:3000/*"
      ]
    },
    {
      "clientId": "portal-backend",
      "enabled": true,
      "bearerOnly": true
    }
  ],
  "users": [
    {
      "username": "portal_user",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "clientRoles": {
        "realm-management": [
          "view-users",
          "query-users",
          "query-groups"
        ]
      }
    }
  ]
}
